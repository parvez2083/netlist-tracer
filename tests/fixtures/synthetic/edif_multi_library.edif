(edif test_multilib
  (edifversion 2 0 0)
  (edifLevel 0)
  (keywordmap (keywordlevel 0))
  (Library tech_lib
    (edifLevel 0)
    (technology (numberDefinition ))
    (cell INV (celltype GENERIC)
      (view netlist (viewtype NETLIST)
        (interface
          (port I (direction INPUT))
          (port O (direction OUTPUT))
        )
      )
    )
    (cell BUF (celltype GENERIC)
      (view netlist (viewtype NETLIST)
        (interface
          (port I (direction INPUT))
          (port O (direction OUTPUT))
        )
      )
    )
  )
  (Library design_lib
    (edifLevel 0)
    (technology (numberDefinition ))
    (cell TOP (celltype GENERIC)
      (view netlist (viewtype NETLIST)
        (interface
          (port A (direction INPUT))
          (port B (direction OUTPUT))
        )
        (contents
          (instance inv_inst (viewref netlist (cellref INV (libraryref tech_lib))))
          (instance buf_inst (viewref netlist (cellref BUF (libraryref tech_lib))))
          (net A (joined
            (portref A)
            (portref I (instanceref inv_inst))
          ))
          (net mid (joined
            (portref O (instanceref inv_inst))
            (portref I (instanceref buf_inst))
          ))
          (net B (joined
            (portref O (instanceref buf_inst))
            (portref B)
          ))
        )
      )
    )
  )
)
