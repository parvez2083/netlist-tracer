(edif test_properties
  (edifversion 2 0 0)
  (edifLevel 0)
  (keywordmap (keywordlevel 0))
  (Library design_lib
    (edifLevel 0)
    (technology (numberDefinition ))
    (cell PROP_TEST (celltype GENERIC)
      (property author (string "ACME"))
      (property width (integer 8))
      (property pi (real 3.14))
      (property enabled (boolean true))
      (view netlist (viewtype NETLIST)
        (interface
          (port A (direction INPUT)
            (property location (string "left"))
          )
          (port B (direction OUTPUT)
            (property location (string "right"))
          )
        )
        (contents
          (instance I1 (viewref netlist (cellref PROP_TEST (libraryref design_lib)))
            (property depth (integer 16))
          )
          (net A (joined
            (portref A)
            (portref A (instanceref I1))
          ))
          (net B (joined
            (portref B)
            (portref B (instanceref I1))
          ))
        )
      )
    )
  )
)
